
{
  "entities": {
    "Product": {
      "title": "Producto",
      "description": "Un producto en el inventario de la ferretería.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Nombre del producto"
        },
        "description": {
          "type": "string",
          "description": "Descripción del producto"
        },
        "price": {
          "type": "number",
          "description": "Precio unitario"
        },
        "quantity": {
          "type": "number",
          "description": "Stock disponible"
        },
        "imageUrl": {
          "type": "string",
          "description": "URL de la imagen del producto"
        },
        "category": {
          "type": "string",
          "description": "Categoría del producto"
        },
        "arrivalDate": {
          "type": "string",
          "format": "date-time",
          "description": "Fecha de ingreso al almacén"
        }
      },
      "required": [
        "name",
        "description",
        "price",
        "quantity",
        "imageUrl"
      ]
    },
    "SaleRecord": {
      "title": "Registro de Venta",
      "description": "Un registro de una transacción de venta completada.",
      "type": "object",
      "properties": {
        "saleDate": {
          "type": "string",
          "format": "date-time",
          "description": "Fecha y hora de la transacción"
        },
        "totalAmount": {
          "type": "number",
          "description": "Monto total de la venta"
        },
        "totalItems": {
          "type": "number",
          "description": "Cantidad total de artículos vendidos"
        },
        "userId": {
          "type": "string",
          "description": "ID del usuario que realizó la compra"
        },
        "itemsSold": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "productId": {
                "type": "string"
              },
              "productName": {
                "type": "string"
              },
              "quantitySold": {
                "type": "number"
              },
              "priceAtSale": {
                "type": "number"
              },
              "category": {
                "type": "string"
              },
              "imageUrl": {
                "type": "string"
              }
            }
          }
        }
      },
      "required": [
        "saleDate",
        "totalAmount",
        "totalItems",
        "itemsSold"
      ]
    }
  },
  "auth": {
    "providers": [
      "password"
    ]
  },
  "firestore": {
    "products/{productId}": {
      "schema": {
        "$ref": "#/entities/Product"
      },
      "description": "Colección de productos en el inventario activo."
    },
    "sales/{saleId}": {
      "schema": {
        "$ref": "#/entities/SaleRecord"
      },
      "description": "Historial de ventas y transacciones de clientes."
    }
  }
}
